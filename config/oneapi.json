  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "name": "Authorization",
        "description": "杈撳叆 JWT token",
        "in": "header"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "autoLogin": {
            "type": "boolean"
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "LoginResponseDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "currentUser": {
            "type": "object",
            "properties": {
              "id": {
                "type": "number"
              },
              "username": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "nullable": true
              },
              "avatar": {
                "type": "string",
                "nullable": true
              },
              "roleId": {
                "type": "number",
                "nullable": true
              },
              "roleName": {
                "type": "string",
                "nullable": true
              },
              "permissions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "id",
              "username",
              "permissions"
            ]
          }
        },
        "required": [
          "token",
          "currentUser"
        ]
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "minLength": 6
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "avatar": {
            "type": "string"
          },
          "roleId": {
            "type": "number"
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "avatar": {
            "type": "string"
          },
          "status": {
            "type": "boolean"
          },
          "roleId": {
            "type": "number"
          }
        }
      },
      "CreateRoleDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "AssignPermissionDto": {
        "type": "object",
        "properties": {
          "permissionIds": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        },
        "required": [
          "permissionIds"
        ]
      },
      "CreateSystemConfigDto": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "object"
          },
          "description": {
            "type": "string"
          },
          "isEncrypted": {
            "type": "boolean"
          }
        },
        "required": [
          "key",
          "value"
        ]
      },
      "UpdateSystemConfigDto": {
        "type": "object",
        "properties": {
          "value": {
            "type": "object"
          },
          "description": {
            "type": "string"
          },
          "isEncrypted": {
            "type": "boolean"
          }
        }
      }
    }
  },
